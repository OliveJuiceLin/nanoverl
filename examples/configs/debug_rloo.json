{
  "data": {
    "train_path": "examples/data/debug_prompts.jsonl",
    "val_path": "examples/data/debug_prompts.jsonl",
    "train_batch_size": 2,
    "val_batch_size": 2,
    "shuffle": false,
    "seed": 11
  },
  "model": {
    "path": "debug-model"
  },
  "algorithm": {
    "name": "rloo"
  },
  "actor": {
    "backend": "debug",
    "mini_batch_size": 2,
    "update_epochs": 1,
    "update_step_size": 0.02
  },
  "critic": {
    "backend": "debug",
    "enable": false
  },
  "reference": {
    "backend": "debug",
    "enable": false
  },
  "rollout": {
    "backend": "debug",
    "response_length": 32,
    "train": {
      "temperature": 0.8,
      "top_p": 1.0,
      "top_k": -1,
      "do_sample": true,
      "n": 2
    },
    "validation": {
      "temperature": 0.0,
      "top_p": 1.0,
      "top_k": -1,
      "do_sample": false,
      "n": 1
    }
  },
  "reward": {
    "type": "python",
    "function_name": "compute_reward"
  },
  "trainer": {
    "total_epochs": 1,
    "validate_before_train": true,
    "test_freq": 1,
    "save_freq": 0,
    "project_name": "nanoverl",
    "experiment_name": "debug_rloo",
    "default_local_dir": "checkpoints/debug_rloo",
    "loggers": [
      "console"
    ]
  }
}
