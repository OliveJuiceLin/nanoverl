{
  "data": {
    "train_path": "examples/data/debug_prompts.jsonl",
    "val_path": "examples/data/debug_prompts.jsonl",
    "prompt_key": "prompt",
    "train_batch_size": 2,
    "val_batch_size": 2,
    "shuffle": false,
    "seed": 11
  },
  "model": {
    "path": "debug-model"
  },
  "algorithm": {
    "name": "ppo",
    "advantage_estimator": "gae",
    "gamma": 1.0,
    "lam": 1.0,
    "use_kl_in_reward": true,
    "kl_penalty": "low_var_kl",
    "kl_coef": 0.01
  },
  "actor": {
    "backend": "debug",
    "ppo_mini_batch_size": 2,
    "ppo_epochs": 1,
    "clip_ratio": 0.2,
    "use_kl_loss": false,
    "update_step_size": 0.02
  },
  "critic": {
    "backend": "debug",
    "enable": true,
    "ppo_mini_batch_size": 2,
    "ppo_epochs": 1,
    "cliprange_value": 0.5
  },
  "reference": {
    "backend": "debug",
    "enable": true,
    "fixed_kl_offset": -0.1
  },
  "rollout": {
    "backend": "debug",
    "response_length": 32,
    "train": {
      "temperature": 0.8,
      "top_p": 1.0,
      "top_k": -1,
      "do_sample": true,
      "n": 1
    },
    "validation": {
      "temperature": 0.0,
      "top_p": 1.0,
      "top_k": -1,
      "do_sample": false,
      "n": 1
    }
  },
  "reward": {
    "type": "python",
    "function_name": "compute_reward"
  },
  "trainer": {
    "total_epochs": 2,
    "validate_before_train": true,
    "validate_only": false,
    "test_freq": 1,
    "save_freq": 1,
    "critic_warmup": 0,
    "project_name": "nanoverl",
    "experiment_name": "debug_ppo",
    "default_local_dir": "checkpoints/debug_ppo",
    "loggers": [
      "console",
      "file"
    ]
  },
  "ray": {
    "enabled": false
  }
}
